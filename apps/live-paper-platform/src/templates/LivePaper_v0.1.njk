        <!-- Matomo -->
        <script>
            var _paq = window._paq = window._paq || [];
            /* tracker methods like "setCustomDimension" should be called before "trackPageView" */
            _paq.push(['trackPageView']);
            _paq.push(['enableLinkTracking']);
            (function () {
                var u = "//stats.humanbrainproject.eu/";
                _paq.push([
                    'setTrackerUrl',
                    u + 'matomo.php'
                ]);
                _paq.push(['setSiteId', '18']);
                var d = document,
                    g = d.createElement('script'),
                    s = d.getElementsByTagName('script')[0];
                g.async = true;
                g.src = u + 'matomo.js';
                s.parentNode.insertBefore(g, s);
            })();
        </script>
        <!-- End Matomo Code -->
        <script>
            // Toggle the .ngl-loading class on each .ngl-basic-canvas container
            // for the duration of any NGL stage.loadFile(...) call, so the CSS
            // spinner/text is visible while large trajectory files are being
            // downloaded. NGL creates the <canvas> synchronously during Stage
            // construction (long before the data arrives), so a pure
            // :has(canvas) CSS approach would hide the indicator too early.
            //
            // Re-install at DOMContentLoaded and window.load as well as immediately,
            // because the LP's section_custom HTML often loads ngl.js more than once
            // and each subsequent load replaces NGL.Stage.prototype.loadFile with
            // the unwrapped version. The idempotency marker prevents double-wrapping.
            (function () {
                function install() {
                    if (typeof NGL === "undefined" || !NGL.Stage || !NGL.Stage.prototype || !NGL.Stage.prototype.loadFile) {
                        return false;
                    }
                    var current = NGL.Stage.prototype.loadFile;
                    if (current.__nglLoadingWrapped) return true;
                    var wrapper = function () {
                        var container = this.viewer && this.viewer.container;
                        var canvasDiv = container && container.closest && container.closest(".ngl-basic-canvas");
                        if (canvasDiv) canvasDiv.classList.add("ngl-loading");
                        var promise = current.apply(this, arguments);
                        var clear = function () { if (canvasDiv) canvasDiv.classList.remove("ngl-loading"); };
                        promise.then(clear, clear);
                        return promise;
                    };
                    wrapper.__nglLoadingWrapped = true;
                    NGL.Stage.prototype.loadFile = wrapper;
                    return true;
                }
                install();
                document.addEventListener("DOMContentLoaded", install, false);
                window.addEventListener("load", install, false);
            })();

            // Get the modal
            var modal = document.getElementById("myModal");

            {# // Get the button that opens the modal
            var btn = document.getElementById("myBtn"); #}

            {# // When the user clicks on the button, open the modal
            btn.onclick = function() {
                modal.style.display = "block";
            } #}
            
            // When the user clicks anywhere outside of the modal, close it
            window.onclick = function(event) {
                // event.path was a non-standard Chrome property removed in v109;
                // use Element.closest() to check whether the click happened inside #myModal
                if (event.target && event.target.closest && !event.target.closest("#myModal")) {
                    var modal = document.getElementById("myModal");
                    modal.style.display = "none";

                    // reset value of hidden element
                    var hidden_input = document.getElementById("hidden-clone-url");
                    hidden_input.value = "";
                }
            }

            function openCloneDialog(value){
                var modal = document.getElementById("myModal");
                modal.style.display = "block";

                // generate URL for cloning app
                let url = `https://collab-file-cloner.apps.ebrains.eu/#source_file=${encodeURI(value)}&dest_dir=/live-papers/{{ alias }}&file_overwrite=false&auto_run=true`
                console.log(url);

                // save URL to a hidden element
                var hidden_input = document.getElementById("hidden-clone-url");
                hidden_input.value = url;
		    }

            function goToCloneApp() {
                // retrieve URL from hidden element
                var hidden_input = document.getElementById("hidden-clone-url");
                var url = hidden_input.value;

                var link = document.createElement('a');
                link.target = "_blank";
                link.href = url;
                link.rel = "noopener noreferrer";
                document.body.appendChild(link); // you need to add it to the DOM to get FF working
                link.click();
                link.parentNode.removeChild(link); // link.remove(); doesn't work on IE11
            }

            function closeCloneDialog(){
                var modal = document.getElementById("myModal");
                modal.style.display = "none";

                // reset value of hidden element
                var hidden_input = document.getElementById("hidden-clone-url");
                hidden_input.value = "";
		    }
        </script>
